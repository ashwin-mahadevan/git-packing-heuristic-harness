From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Ashwin Mahadevan <mahadevan@ashwinm.com>
Date: Fri, 1 May 2026 01:48:23 -0700
Subject: [PATCH] pack-objects: add --delta-strategy, --record-strategy,
 --include-reused

Add support for delegating delta parent selection to an external
process. When --delta-strategy=<cmd> is given, pack-objects groups
candidates by object type, invokes the command once per type, streams
candidate descriptors via stdin, reads back (child, parent)
assignments, and applies them directly.

Also add --record-strategy=<file> to dump the default algorithm's
assignments for replay/comparison, and --include-reused to include
entries with reused on-disk deltas in the strategy input.

Based on git v2.47.0 (777489f9e0).
---
 builtin/pack-objects.c | 302 ++++++++++++++++++++++++++++++++++++++++-
 1 file changed, 298 insertions(+), 4 deletions(-)

diff --git a/builtin/pack-objects.c b/builtin/pack-objects.c
index 0fc0680b40..4666069100 100644
--- a/builtin/pack-objects.c
+++ b/builtin/pack-objects.c
@@ -38,6 +38,7 @@
 #include "shallow.h"
 #include "promisor-remote.h"
 #include "pack-mtimes.h"
+#include "run-command.h"
 #include "parse-options.h"

 /*
@@ -242,6 +243,10 @@ static int exclude_promisor_objects;

 static int use_delta_islands;

+static const char *delta_strategy_cmd;
+static const char *record_strategy_file;
+static int include_reused;
+
 static unsigned long delta_cache_size = 0;
 static unsigned long max_delta_cache_size = DEFAULT_DELTA_CACHE_SIZE;
 static unsigned long cache_max_small_delta_size = 1000;
@@ -3167,6 +3172,273 @@ static int add_ref_tag(const char *tag UNUSED, const char *referent UNUSED, cons
 	return 0;
 }

+
+/*
+ * --delta-strategy=<cmd> support.
+ *
+ * Instead of QSORT + ll_find_deltas, spawn an external process, stream
+ * candidate descriptors to it, read back (child, parent) assignments,
+ * and trust them directly.  Objects are grouped by type so the strategy
+ * is invoked once per type — cross-type assignments are impossible.
+ */
+
+struct strategy_proposal {
+	struct object_entry *child;
+	struct object_entry *parent;
+	int parent_is_ext;
+	struct object_id parent_oid;
+};
+
+static intmax_t strategy_stat_attempted;
+static intmax_t strategy_stat_accepted;
+
+static struct object_entry *find_entry_by_oid(const struct object_id *oid)
+{
+	return packlist_find(&to_pack, oid);
+}
+
+static void write_descriptors(int fd, struct object_entry **list, unsigned n)
+{
+	unsigned i;
+	struct strbuf buf = STRBUF_INIT;
+
+	for (i = 0; i < n; i++) {
+		struct object_entry *entry = list[i];
+		const char *type_str = type_name(oe_type(entry));
+		unsigned long size = SIZE(entry);
+		struct object_entry *reused_base = DELTA(entry);
+
+		strbuf_reset(&buf);
+		strbuf_addf(&buf, "%s %s %lu %08"PRIx32" %d %s\n",
+			    oid_to_hex(&entry->idx.oid),
+			    type_str,
+			    size,
+			    entry->hash,
+			    entry->preferred_base ? 1 : 0,
+			    reused_base ? oid_to_hex(&reused_base->idx.oid) : "NONE");
+
+		if (write_in_full(fd, buf.buf, buf.len) < 0)
+			die_errno(_("failed to write to delta strategy process"));
+	}
+
+	if (write_in_full(fd, "\n", 1) < 0)
+		die_errno(_("failed to write terminator to delta strategy process"));
+
+	strbuf_release(&buf);
+}
+
+static void read_assignments(FILE *fp, struct strategy_proposal **out,
+			     unsigned *out_nr)
+{
+	struct strbuf line = STRBUF_INIT;
+	struct strategy_proposal *proposals = NULL;
+	unsigned nr = 0, alloc = 0;
+
+	while (strbuf_getline_lf(&line, fp) == 0) {
+		struct object_id child_oid, parent_oid;
+		struct object_entry *child_entry;
+		const char *p;
+		int has_parent;
+
+		if (!line.len)
+			break;
+
+		p = line.buf;
+		if (parse_oid_hex(p, &child_oid, &p) || *p != ' ')
+			die(_("malformed delta strategy assignment: %s"), line.buf);
+		p++;
+
+		child_entry = find_entry_by_oid(&child_oid);
+		if (!child_entry)
+			die(_("delta strategy referenced unknown child: %s"),
+			    oid_to_hex(&child_oid));
+
+		if (child_entry->preferred_base)
+			die(_("delta strategy assigned a preferred_base as child: %s"),
+			    oid_to_hex(&child_oid));
+
+		has_parent = strcmp(p, "NONE") != 0;
+
+		ALLOC_GROW(proposals, nr + 1, alloc);
+		proposals[nr].child = child_entry;
+		proposals[nr].parent = NULL;
+		proposals[nr].parent_is_ext = 0;
+
+		if (has_parent) {
+			const char *end;
+			if (parse_oid_hex(p, &parent_oid, &end) || *end != '\0')
+				die(_("malformed parent oid in strategy assignment: %s"), p);
+
+			oidcpy(&proposals[nr].parent_oid, &parent_oid);
+			proposals[nr].parent = find_entry_by_oid(&parent_oid);
+
+			if (!proposals[nr].parent) {
+				if (bitmap_git &&
+				    bitmap_has_oid_in_uninteresting(bitmap_git, &parent_oid))
+					proposals[nr].parent_is_ext = 1;
+				else
+					die(_("delta strategy parent %s not in pack and not thin-eligible"),
+					    oid_to_hex(&parent_oid));
+			}
+		}
+
+		nr++;
+	}
+
+	strbuf_release(&line);
+
+	*out = proposals;
+	*out_nr = nr;
+}
+
+static void apply_strategy_proposals(struct strategy_proposal *proposals,
+				     unsigned nr)
+{
+	unsigned i;
+
+	for (i = 0; i < nr; i++) {
+		struct strategy_proposal *p = &proposals[i];
+		void *trg_buf, *src_buf, *delta_buf;
+		unsigned long trg_size, src_size, delta_size;
+		enum object_type type;
+
+		if (!p->parent && !p->parent_is_ext)
+			continue;
+
+		strategy_stat_attempted++;
+
+		if (p->parent_is_ext) {
+			SET_DELTA_EXT(p->child, &p->parent_oid);
+			strategy_stat_accepted++;
+			continue;
+		}
+
+		trg_buf = repo_read_object_file(the_repository,
+						&p->child->idx.oid,
+						&type, &trg_size);
+		if (!trg_buf)
+			die(_("object %s cannot be read"),
+			    oid_to_hex(&p->child->idx.oid));
+
+		src_buf = repo_read_object_file(the_repository,
+						&p->parent->idx.oid,
+						&type, &src_size);
+		if (!src_buf)
+			die(_("object %s cannot be read"),
+			    oid_to_hex(&p->parent->idx.oid));
+
+		delta_buf = diff_delta(src_buf, src_size,
+				       trg_buf, trg_size,
+				       &delta_size, 0);
+		free(trg_buf);
+		free(src_buf);
+
+		if (!delta_buf) {
+			warning(_("delta computation failed for %s -> %s"),
+				oid_to_hex(&p->child->idx.oid),
+				oid_to_hex(&p->parent->idx.oid));
+			continue;
+		}
+		free(delta_buf);
+
+		SET_DELTA(p->child, p->parent);
+		SET_DELTA_SIZE(p->child, delta_size);
+		strategy_stat_accepted++;
+	}
+}
+
+static void run_strategy_for_entries(struct object_entry **list, unsigned n)
+{
+	struct child_process strategy = CHILD_PROCESS_INIT;
+	struct strategy_proposal *proposals = NULL;
+	unsigned proposal_nr = 0;
+	FILE *fp;
+
+	strvec_push(&strategy.args, delta_strategy_cmd);
+	strategy.in = -1;
+	strategy.out = -1;
+	strategy.use_shell = 1;
+
+	if (start_command(&strategy))
+		die(_("failed to start delta strategy command: %s"),
+		    delta_strategy_cmd);
+
+	write_descriptors(strategy.in, list, n);
+	close(strategy.in);
+
+	fp = fdopen(strategy.out, "r");
+	if (!fp)
+		die_errno(_("fdopen failed for delta strategy output"));
+
+	read_assignments(fp, &proposals, &proposal_nr);
+	fclose(fp);
+
+	if (finish_command(&strategy))
+		die(_("delta strategy command failed: %s"), delta_strategy_cmd);
+
+	if (proposal_nr > 0)
+		apply_strategy_proposals(proposals, proposal_nr);
+
+	free(proposals);
+}
+
+static void run_external_delta_strategy(struct object_entry **delta_list,
+					unsigned n)
+{
+	int types[] = { OBJ_COMMIT, OBJ_TREE, OBJ_BLOB, OBJ_TAG };
+	unsigned t;
+
+	strategy_stat_attempted = 0;
+	strategy_stat_accepted = 0;
+
+	for (t = 0; t < ARRAY_SIZE(types); t++) {
+		struct object_entry **type_list;
+		unsigned type_n = 0, i;
+
+		ALLOC_ARRAY(type_list, n);
+		for (i = 0; i < n; i++) {
+			if (oe_type(delta_list[i]) == types[t])
+				type_list[type_n++] = delta_list[i];
+		}
+
+		if (type_n > 0)
+			run_strategy_for_entries(type_list, type_n);
+
+		free(type_list);
+	}
+
+	trace2_data_intmax("pack-objects", the_repository,
+			   "delta-strategy/attempted", strategy_stat_attempted);
+	trace2_data_intmax("pack-objects", the_repository,
+			   "delta-strategy/accepted", strategy_stat_accepted);
+}
+
+static void record_strategy_results(struct object_entry **delta_list,
+				    unsigned n, const char *filename)
+{
+	FILE *fp;
+	unsigned i;
+
+	fp = fopen(filename, "w");
+	if (!fp)
+		die_errno(_("cannot open record-strategy file '%s'"), filename);
+
+	for (i = 0; i < n; i++) {
+		struct object_entry *entry = delta_list[i];
+		struct object_entry *base;
+
+		if (entry->preferred_base)
+			continue;
+
+		base = DELTA(entry);
+		fprintf(fp, "%s %s\n",
+			oid_to_hex(&entry->idx.oid),
+			base ? oid_to_hex(&base->idx.oid) : "NONE");
+	}
+
+	fclose(fp);
+}
+
 static void prepare_pack(int window, int depth)
 {
 	struct object_entry **delta_list;
@@ -3188,7 +3460,8 @@ static void prepare_pack(int window, int depth)
 	if (!pack_to_stdout)
 		do_check_packed_object_crc = 1;

-	if (!to_pack.nr_objects || !window || !depth)
+	if (!to_pack.nr_objects ||
+	    (!delta_strategy_cmd && (!window || !depth)))
 		return;

 	ALLOC_ARRAY(delta_list, to_pack.nr_objects);
@@ -3197,11 +3470,13 @@ static void prepare_pack(int window, int depth)
 	for (i = 0; i < to_pack.nr_objects; i++) {
 		struct object_entry *entry = to_pack.objects + i;

-		if (DELTA(entry))
+		if (DELTA(entry)) {
 			/* This happens if we decided to reuse existing
 			 * delta from a pack.  "reuse_delta &&" is implied.
 			 */
-			continue;
+			if (!include_reused || !delta_strategy_cmd)
+				continue;
+		}

 		if (!entry->type_valid ||
 		    oe_size_less_than(&to_pack, entry, 50))
@@ -3228,7 +3503,10 @@ static void prepare_pack(int window, int depth)
 		delta_list[n++] = entry;
 	}

-	if (nr_deltas && n > 1) {
+	if (delta_strategy_cmd) {
+		if (n > 0)
+			run_external_delta_strategy(delta_list, n);
+	} else if (nr_deltas && n > 1) {
 		unsigned nr_done = 0;

 		if (progress)
@@ -3239,7 +3517,12 @@ static void prepare_pack(int window, int depth)
 		stop_progress(&progress_state);
 		if (nr_done != nr_deltas)
 			die(_("inconsistency with delta count"));
+
+		if (record_strategy_file)
+			record_strategy_results(delta_list, n,
+						record_strategy_file);
 	}
+
 	free(delta_list);
 }

@@ -4426,6 +4709,14 @@ int cmd_pack_objects(int argc,
 			 N_("do not pack objects in promisor packfiles")),
 		OPT_BOOL(0, "delta-islands", &use_delta_islands,
 			 N_("respect islands during delta compression")),
+		OPT_STRING(0, "delta-strategy", &delta_strategy_cmd,
+			   N_("cmd"),
+			   N_("use external command for delta parent selection")),
+		OPT_STRING(0, "record-strategy", &record_strategy_file,
+			   N_("file"),
+			   N_("record delta parent assignments to file")),
+		OPT_BOOL(0, "include-reused", &include_reused,
+			 N_("include reused-delta entries in strategy input")),
 		OPT_STRING_LIST(0, "uri-protocol", &uri_protocols,
 				N_("protocol"),
 				N_("exclude any configured uploadpack.blobpackfileuri with this protocol")),
--
2.47.0
