+/*
+ * --delta-strategy=<cmd> support.
+ *
+ * Instead of QSORT + ll_find_deltas, spawn an external process, stream
+ * candidate descriptors to it, read back (child, parent) assignments,
+ * and trust them directly.  The strategy is responsible for any type
+ * filtering it cares about; we apply the assignments verbatim.
+ */
+
+struct strategy_proposal {
+	struct object_entry *child;
+	struct object_entry *parent;
+	int parent_is_ext;
+	struct object_id parent_oid;
+};
+
+static struct object_entry *find_entry_by_oid(const struct object_id *oid)
+{
+	return packlist_find(&to_pack, oid);
+}
+
+static void build_descriptors(struct strbuf *out,
+			      struct object_entry **list, unsigned n)
+{
+	unsigned i;
+
+	for (i = 0; i < n; i++) {
+		struct object_entry *entry = list[i];
+		struct object_entry *reused_base = DELTA(entry);
+
+		strbuf_addf(out, "D %s %s %lu %08"PRIx32" %d %s\n",
+			    oid_to_hex(&entry->idx.oid),
+			    type_name(oe_type(entry)),
+			    (unsigned long)SIZE(entry),
+			    entry->hash,
+			    entry->preferred_base ? 1 : 0,
+			    reused_base ? oid_to_hex(&reused_base->idx.oid) : "NONE");
+	}
+
+	strbuf_addch(out, '\n');
+}
+
+static int parse_oid_field(const char *buf, size_t len, struct object_id *oid)
+{
+	char hex[GIT_MAX_HEXSZ + 1];
+	const char *end;
+
+	if (len > GIT_MAX_HEXSZ)
+		return -1;
+	memcpy(hex, buf, len);
+	hex[len] = '\0';
+	if (parse_oid_hex(hex, oid, &end) || *end != '\0')
+		return -1;
+	return 0;
+}
+
+static void handle_query(const char *line, size_t len, struct strbuf *out)
+{
+	struct object_id child_oid, parent_oid;
+	struct object_entry *child_entry, *parent_entry;
+	void *child_buf, *parent_buf, *delta_buf;
+	unsigned long child_size, parent_size, delta_size;
+	unsigned long max_size = 0;
+	enum object_type type;
+	const char *p, *end;
+	char *endp;
+
+	if (len < 4 || line[0] != 'Q' || line[1] != ' ')
+		die(_("malformed strategy query: %.*s"), (int)len, line);
+	p = line + 2;
+	if (parse_oid_hex(p, &child_oid, &p) || *p != ' ')
+		die(_("malformed strategy query (child): %.*s"), (int)len, line);
+	p++;
+
+	end = memchr(p, ' ', (line + len) - p);
+	if (end) {
+		if (parse_oid_field(p, end - p, &parent_oid))
+			die(_("malformed strategy query (parent): %.*s"),
+			    (int)len, line);
+		p = end + 1;
+		errno = 0;
+		max_size = strtoul(p, &endp, 10);
+		if (errno || endp != line + len)
+			die(_("malformed strategy query (max_size): %.*s"),
+			    (int)len, line);
+	} else {
+		if (parse_oid_field(p, (line + len) - p, &parent_oid))
+			die(_("malformed strategy query (parent): %.*s"),
+			    (int)len, line);
+	}
+
+	child_entry = find_entry_by_oid(&child_oid);
+	if (!child_entry)
+		die(_("strategy queried unknown child: %s"),
+		    oid_to_hex(&child_oid));
+
+	parent_entry = find_entry_by_oid(&parent_oid);
+
+	child_buf = odb_read_object(the_repository->objects, &child_oid,
+				    &type, &child_size);
+	if (!child_buf)
+		die(_("unable to read %s"), oid_to_hex(&child_oid));
+
+	parent_buf = odb_read_object(the_repository->objects, &parent_oid,
+				     &type, &parent_size);
+	if (!parent_buf) {
+		free(child_buf);
+		strbuf_addf(out, "R %s %s\n",
+			    oid_to_hex(&child_oid), oid_to_hex(&parent_oid));
+		return;
+	}
+
+	delta_buf = diff_delta(parent_buf, parent_size,
+			       child_buf, child_size, &delta_size, max_size);
+	free(child_buf);
+	free(parent_buf);
+
+	if (!delta_buf) {
+		strbuf_addf(out, "R %s %s\n",
+			    oid_to_hex(&child_oid), oid_to_hex(&parent_oid));
+		return;
+	}
+
+	strbuf_addf(out, "R %s %s %lu\n",
+		    oid_to_hex(&child_oid), oid_to_hex(&parent_oid), delta_size);
+
+	/*
+	 * Cache the delta on child_entry for reuse at pack-write time --
+	 * but only if the parent is in to_pack (so DELTA can point at it)
+	 * and this is the smallest delta seen so far for this child.
+	 */
+	if (parent_entry &&
+	    (!DELTA(child_entry) || delta_size < DELTA_SIZE(child_entry)) &&
+	    delta_cacheable(parent_size, child_size, delta_size)) {
+		if (child_entry->delta_data) {
+			delta_cache_size -= DELTA_SIZE(child_entry);
+			free(child_entry->delta_data);
+		}
+		delta_cache_size += delta_size;
+		child_entry->delta_data = xrealloc(delta_buf, delta_size);
+		SET_DELTA(child_entry, parent_entry);
+		SET_DELTA_SIZE(child_entry, delta_size);
+	} else {
+		free(delta_buf);
+	}
+}
+
+static void parse_assignment_line(const char *line, size_t len,
+				  struct strategy_proposal *out)
+{
+	struct object_id child_oid;
+	struct object_entry *child_entry;
+	const char *p;
+	size_t plen;
+
+	if (len < 4 || line[0] != 'A' || line[1] != ' ')
+		die(_("malformed strategy assignment: %.*s"), (int)len, line);
+	p = line + 2;
+	if (parse_oid_hex(p, &child_oid, &p) || *p != ' ')
+		die(_("malformed strategy assignment (child): %.*s"), (int)len, line);
+	p++;
+
+	child_entry = find_entry_by_oid(&child_oid);
+	if (!child_entry)
+		die(_("strategy referenced unknown child: %s"),
+		    oid_to_hex(&child_oid));
+	if (child_entry->preferred_base)
+		die(_("strategy assigned a preferred_base as child: %s"),
+		    oid_to_hex(&child_oid));
+
+	out->child = child_entry;
+	out->parent = NULL;
+	out->parent_is_ext = 0;
+
+	plen = (line + len) - p;
+	if (plen == 4 && !memcmp(p, "NONE", 4))
+		return;
+
+	if (parse_oid_field(p, plen, &out->parent_oid))
+		die(_("malformed strategy assignment (parent): %.*s"), (int)len, line);
+
+	out->parent = find_entry_by_oid(&out->parent_oid);
+	if (!out->parent) {
+		if (bitmap_git &&
+		    bitmap_has_oid_in_uninteresting(bitmap_git, &out->parent_oid))
+			out->parent_is_ext = 1;
+		else
+			die(_("strategy parent %s not in pack and not thin-eligible"),
+			    oid_to_hex(&out->parent_oid));
+	}
+}
+
+static void invalidate_cached_delta(struct object_entry *e)
+{
+	if (e->delta_data) {
+		delta_cache_size -= DELTA_SIZE(e);
+		FREE_AND_NULL(e->delta_data);
+	}
+}
+
+static void apply_strategy_proposals(struct strategy_proposal *proposals,
+				     unsigned nr)
+{
+	unsigned i;
+
+	for (i = 0; i < nr; i++) {
+		struct strategy_proposal *p = &proposals[i];
+
+		if (!p->parent && !p->parent_is_ext) {
+			invalidate_cached_delta(p->child);
+			if (DELTA(p->child))
+				SET_DELTA(p->child, NULL);
+			continue;
+		}
+
+		if (p->parent_is_ext) {
+			invalidate_cached_delta(p->child);
+			SET_DELTA_EXT(p->child, &p->parent_oid);
+			continue;
+		}
+
+		if (DELTA(p->child) == p->parent)
+			continue;
+
+		invalidate_cached_delta(p->child);
+		SET_DELTA(p->child, p->parent);
+	}
+}
+
+static void dispatch_strategy_line(const char *line, size_t len,
+				   struct strbuf *to_child,
+				   struct strategy_proposal **proposals,
+				   unsigned *nr, unsigned *alloc,
+				   int *done)
+{
+	if (len == 0) {
+		*done = 1;
+		return;
+	}
+	if (line[0] == 'Q') {
+		handle_query(line, len, to_child);
+	} else if (line[0] == 'A') {
+		ALLOC_GROW(*proposals, *nr + 1, *alloc);
+		parse_assignment_line(line, len, &(*proposals)[*nr]);
+		(*nr)++;
+	} else {
+		die(_("unknown strategy line: %.*s"), (int)len, line);
+	}
+}
+
+static void run_external_delta_strategy(struct object_entry **list, unsigned n)
+{
+	struct child_process strategy = CHILD_PROCESS_INIT;
+	struct strbuf to_child = STRBUF_INIT;
+	struct strbuf from_child = STRBUF_INIT;
+	struct strategy_proposal *proposals = NULL;
+	unsigned proposal_nr = 0, proposal_alloc = 0;
+	size_t write_off = 0;
+	int done = 0;
+
+	strvec_push(&strategy.args, delta_strategy_cmd);
+	strategy.in = -1;
+	strategy.out = -1;
+	strategy.use_shell = 1;
+
+	if (start_command(&strategy))
+		die(_("failed to start delta strategy command: %s"),
+		    delta_strategy_cmd);
+
+	if (enable_pipe_nonblock(strategy.in) < 0)
+		die_errno(_("unable to make strategy stdin non-blocking"));
+
+	build_descriptors(&to_child, list, n);
+
+	while (!done) {
+		struct pollfd pfds[2];
+		int nfds = 0, in_idx = -1, out_idx = -1;
+
+		if (write_off < to_child.len && strategy.in >= 0) {
+			pfds[nfds].fd = strategy.in;
+			pfds[nfds].events = POLLOUT;
+			in_idx = nfds++;
+		}
+		pfds[nfds].fd = strategy.out;
+		pfds[nfds].events = POLLIN;
+		out_idx = nfds++;
+
+		if (poll(pfds, nfds, -1) < 0) {
+			if (errno == EINTR)
+				continue;
+			die_errno(_("poll failed in strategy loop"));
+		}
+
+		if (in_idx >= 0) {
+			short re = pfds[in_idx].revents;
+			if (re & POLLOUT) {
+				size_t want = to_child.len - write_off;
+				ssize_t w;
+
+				if (want > MAX_IO_SIZE)
+					want = MAX_IO_SIZE;
+				w = write(strategy.in, to_child.buf + write_off, want);
+				if (w < 0) {
+					if (errno != EINTR && errno != EAGAIN) {
+						close(strategy.in);
+						strategy.in = -1;
+					}
+				} else {
+					write_off += w;
+					if (write_off == to_child.len) {
+						strbuf_reset(&to_child);
+						write_off = 0;
+					}
+				}
+			}
+			if (re & (POLLERR|POLLHUP|POLLNVAL)) {
+				close(strategy.in);
+				strategy.in = -1;
+			}
+		}
+
+		if (pfds[out_idx].revents & (POLLIN|POLLHUP|POLLERR)) {
+			ssize_t r = strbuf_read_once(&from_child, strategy.out, 4096);
+			if (r < 0 && errno != EINTR && errno != EAGAIN)
+				die_errno(_("read from strategy"));
+			if (r == 0)
+				done = 1;
+
+			while (!done) {
+				char *nl = memchr(from_child.buf, '\n', from_child.len);
+				size_t llen;
+				if (!nl)
+					break;
+				llen = nl - from_child.buf;
+				dispatch_strategy_line(from_child.buf, llen,
+						       &to_child,
+						       &proposals, &proposal_nr,
+						       &proposal_alloc, &done);
+				strbuf_remove(&from_child, 0, llen + 1);
+			}
+		}
+	}
+
+	if (strategy.in >= 0) {
+		close(strategy.in);
+		strategy.in = -1;
+	}
+
+	if (finish_command(&strategy))
+		die(_("delta strategy command failed: %s"), delta_strategy_cmd);
+
+	if (proposal_nr > 0)
+		apply_strategy_proposals(proposals, proposal_nr);
+
+	free(proposals);
+	strbuf_release(&to_child);
+	strbuf_release(&from_child);
+}
+
+static void record_strategy_results(struct object_entry **delta_list,
+				    unsigned n, const char *filename)
+{
+	FILE *fp;
+	unsigned i;
+
+	fp = fopen(filename, "w");
+	if (!fp)
+		die_errno(_("cannot open record-strategy file '%s'"), filename);
+
+	for (i = 0; i < n; i++) {
+		struct object_entry *entry = delta_list[i];
+		struct object_entry *base;
+
+		if (entry->preferred_base)
+			continue;
+
+		base = DELTA(entry);
+		fprintf(fp, "%s %s\n",
+			oid_to_hex(&entry->idx.oid),
+			base ? oid_to_hex(&base->idx.oid) : "NONE");
+	}
+
+	fclose(fp);
+}
